<Window x:Class="FiestaLauncher.Views.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launcher Login"
        Height="330"
        Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF111116"
        WindowStyle="None"
        AllowsTransparency="False">

    <Border Margin="1"
            Padding="26"
            Background="{StaticResource HeroGlassBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Launcher Login"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"/>

            <TextBlock Grid.Row="1"
                       Margin="0,10,0,0"
                       Text="Der Launcher holt jetzt die Start-Session direkt ueber dein Konto."
                       Foreground="{StaticResource SubTextBrush}"
                       TextWrapping="Wrap"/>

            <TextBlock Grid.Row="2"
                       Margin="0,18,0,6"
                       Text="Username"
                       Foreground="{StaticResource SecondaryBrush}"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="txtUsername"
                     Grid.Row="3"
                     Height="38"
                     Padding="12,8"
                     Background="{StaticResource InputBgBrush}"
                     Foreground="White"
                     BorderBrush="{StaticResource PanelBorderBrush}"
                     BorderThickness="1"/>

            <StackPanel Grid.Row="4" Margin="0,14,0,0">
                <TextBlock Text="Password"
                           Foreground="{StaticResource SecondaryBrush}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <PasswordBox x:Name="txtPassword"
                             Height="38"
                             Padding="12,8"
                             Background="{StaticResource InputBgBrush}"
                             Foreground="White"
                             BorderBrush="{StaticResource PanelBorderBrush}"
                             BorderThickness="1"/>
            </StackPanel>

            <Grid Grid.Row="5" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Margin="0,0,6,0"
                        Content="CANCEL"
                        Style="{StaticResource SecondaryButton}"
                        Height="42"
                        IsCancel="True"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="1"
                        Margin="6,0,0,0"
                        Content="LOGIN"
                        Style="{StaticResource FiestaButton}"
                        Height="42"
                        IsDefault="True"
                        Click="LoginButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
