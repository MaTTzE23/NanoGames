<Window x:Class="FiestaLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NanOnline Launcher"
        Width="1200"
        Height="720"
        MinWidth="1200"
        MaxWidth="1200"
        MinHeight="720"
        MaxHeight="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#FF06070D"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid ClipToBounds="True">
        <Image Source="Resources/Images/LauncherBackground.jpg"
               Stretch="UniformToFill"
               Opacity="0.99"
               RenderTransformOrigin="0.52,0.46">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1.06" ScaleY="1.06"/>
                    <TranslateTransform X="-12" Y="-6"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>

        <Rectangle Fill="#3003060A"/>

        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#4503050A" Offset="0"/>
                    <GradientStop Color="#1003050A" Offset="0.28"/>
                    <GradientStop Color="#5C03050A" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.49,0.43"
                                     GradientOrigin="0.49,0.43"
                                     RadiusX="0.95"
                                     RadiusY="0.9">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#2503050A" Offset="0.56"/>
                    <GradientStop Color="#A803050A" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Ellipse Width="520"
                 Height="180"
                 Fill="#1D7D36FF"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 Margin="0,0,0,-56"
                 IsHitTestVisible="False"/>

        <Ellipse Width="640"
                 Height="220"
                 Fill="#198F45FF"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 Margin="0,0,0,-92"
                 IsHitTestVisible="False"/>

        <Grid Margin="28,18,28,18">
            <TextBlock x:Name="txtVersion"
                       Visibility="Collapsed"/>

            <Grid HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Panel.ZIndex="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="—"
                        Style="{StaticResource TitleBarControlButton}"
                        Margin="0,0,10,0"
                        Click="MinimizeButton_Click"/>

                <Button Grid.Column="1"
                        Content="X"
                        Style="{StaticResource TitleBarControlButton}"
                        Click="CloseButton_Click"/>
            </Grid>

            <Canvas Margin="0,12,0,0">
                <Grid x:Name="btnLogo"
                      Canvas.Left="700"
                      Canvas.Top="28"
                      Width="388"
                      Height="286"
                      Panel.ZIndex="15"
                      IsHitTestVisible="False">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="logoScaleTransform" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Grid.Effect>
                            <DropShadowEffect x:Name="logoShadowEffect"
                                              BlurRadius="48"
                                              ShadowDepth="0"
                                              Color="#BA7A41FF"
                                              Opacity="0.95"/>
                        </Grid.Effect>
                        <Image Source="Resources/Images/NanoGamesLogo.png"
                               Stretch="Uniform"/>
                    </Grid>
                </Grid>

                <Border Canvas.Left="8"
                        Canvas.Top="250"
                        Width="690"
                        Height="250"
                        Padding="26,22,26,20"
                        CornerRadius="26"
                        Background="{StaticResource HeroGlassBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1.1"
                        Panel.ZIndex="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#3A05070F"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="txtServerName"
                                   Visibility="Collapsed"
                                   Text="NanOnline"/>

                        <StackPanel x:Name="newsPanel"
                                    Grid.Row="0"/>

                        <Grid Grid.Row="1" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Ellipse x:Name="statusIndicator"
                                             Width="10"
                                             Height="10"
                                             Margin="0,0,10,0"
                                             Fill="{StaticResource WarningBrush}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="Patchserver "
                                               Foreground="{StaticResource PrimaryBrush}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtConnectionStatus"
                                               Text="Offline"
                                               Foreground="{StaticResource WarningBrush}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock x:Name="txtActionStatus"
                                           Margin="20,7,0,0"
                                           Text=""
                                           Foreground="{StaticResource SubTextBrush}"
                                           FontSize="12"
                                           Visibility="Collapsed"/>
                            </StackPanel>

                            <TextBlock x:Name="txtLauncherState"
                                       Grid.Column="1"
                                       Text="Ready"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Canvas.Left="758"
                        Canvas.Top="286"
                        Width="392"
                        Height="224"
                        Padding="26,22,26,20"
                        CornerRadius="26"
                        Background="{StaticResource HeroGlassBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1.1"
                        Panel.ZIndex="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#3A05070F"/>
                    </Border.Effect>

                    <Grid>
                        <TextBlock x:Name="txtLoginPanelTitle"
                                   Visibility="Collapsed"
                                   Text="LOGIN"/>

                        <TextBlock x:Name="txtLoginPanelSubtitle"
                                   Visibility="Collapsed"
                                   Text=""/>

                        <StackPanel x:Name="loginFormPanel">
                            <TextBox x:Name="txtInlineUsername"
                                     Height="48"
                                     Tag="Username"
                                     Style="{StaticResource LauncherTextBoxStyle}"/>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="88"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <PasswordBox x:Name="pwdInlinePassword"
                                                 Height="48"
                                                 Style="{StaticResource LauncherPasswordBoxStyle}"
                                                 PasswordChanged="PwdInlinePassword_PasswordChanged"
                                                 KeyDown="PasswordInput_KeyDown"/>

                                    <TextBox x:Name="txtInlinePassword"
                                             Height="48"
                                             Tag="Password"
                                             Visibility="Collapsed"
                                             Style="{StaticResource LauncherTextBoxStyle}"
                                             TextChanged="TxtInlinePassword_TextChanged"
                                             KeyDown="PasswordInput_KeyDown"/>

                                    <TextBlock x:Name="txtPasswordWatermark"
                                               Text="Password"
                                               Margin="16,0,0,0"
                                               Foreground="#7AB3BDD5"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"/>
                                </Grid>

                                <Button x:Name="btnPasswordToggle"
                                        Grid.Column="1"
                                        Width="78"
                                        Height="48"
                                        Margin="10,0,0,0"
                                        Content="VIEW"
                                        FontSize="12"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnPasswordToggle_Click"/>
                            </Grid>

                            <TextBlock x:Name="txtLoginError"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource ErrorBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"/>

                            <Button x:Name="btnForgotPassword"
                                    Margin="0,12,0,0"
                                    Content="Forgot password?"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource LinkButtonStyle}"
                                    Click="BtnForgotPassword_Click"/>
                        </StackPanel>

                        <StackPanel x:Name="sessionReadyPanel"
                                    Visibility="Collapsed"
                                    VerticalAlignment="Center">
                            <TextBlock Text="LOGGED IN"
                                       Foreground="{StaticResource SecondaryBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="txtSessionUser"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <Button x:Name="btnCheckUpdate"
                                    Content="CHECK UPDATES"
                                    Height="40"
                                    Margin="0,16,0,0"
                                    Visibility="Collapsed"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnCheckUpdate_Click"/>
                            <CheckBox x:Name="chkAutoLaunch"
                                      Margin="0,12,0,0"
                                      Content="Spiel nach dem Patch automatisch starten"
                                      Visibility="Collapsed"
                                      Style="{StaticResource FiestaCheckBox}"/>
                        </StackPanel>

                        <Button x:Name="btnStartGame"
                                Content="LOGIN"
                                Height="54"
                                Margin="0,0,0,0"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource FiestaButton}"
                                Click="BtnStartGame_Click"/>
                    </Grid>
                </Border>

                <Border Canvas.Left="8"
                        Canvas.Top="538"
                        Width="1140"
                        Height="118"
                        Padding="22,16,22,16"
                        CornerRadius="24"
                        Background="{StaticResource HeroGlassBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1.1"
                        Panel.ZIndex="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#3A05070F"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="txtPatchStatus"
                                       Text="Client ready"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontSize="17"
                                       FontWeight="Bold"/>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Patch-Version: "
                                           Foreground="{StaticResource SecondaryBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtPatchVersionInfo"
                                           Text="-"
                                           Foreground="{StaticResource AccentSoftBrush}"
                                           FontSize="13"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>

                        <ProgressBar x:Name="progressBar"
                                     Grid.Row="1"
                                     Margin="0,14,0,0"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"
                                     Style="{StaticResource FiestaProgressBar}"/>

                        <TextBlock x:Name="txtPatchProgress"
                                   Grid.Row="2"
                                   Margin="0,12,0,0"
                                   Foreground="{StaticResource SubTextBrush}"
                                   FontSize="12"
                                   Text="Ready to launch."
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>
            </Canvas>

            <TextBox x:Name="txtLog"
                     Visibility="Collapsed"
                     IsReadOnly="True"/>
        </Grid>
    </Grid>
</Window>
